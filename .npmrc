# `--legacy-peer-deps` is required because `@kerv-one/theme` (vendored
# at `./kerv-one-theme/`) depends on MUI 6 nested packages while this
# project uses MUI 7 at the top level. Without the flag, npm refuses
# to install (peer-dep mismatch) OR resolves a different tree that
# introduces a duplicate `@mui/system` — which breaks MUI's
# single-instance invariant at runtime (`alpha is not a function`,
# `lighten is not a function`, etc., per the Vercel deploy that hit
# this without the flag).
#
# The `package.json` `overrides` block separately hoists
# `@kerv-one/theme`'s `@mui/material` to the root version; this `.npmrc`
# just makes sure every install honors the legacy peer-dep flag in the
# first place. Codifying it in-repo means Vercel, CI, and any fresh
# checkout pick it up automatically — no per-environment config required.
legacy-peer-deps=true
