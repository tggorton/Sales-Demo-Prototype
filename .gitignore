# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules

# One-off review artifacts generated from source JSON; regenerable on demand.
/dhyh-products.json
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment overrides (see .env.example for template)
.env.local
.env.*.local

# Local-only media (too large for GitHub – reference via VITE_* overrides instead)
public/assets/video/dhyh-cmp-full.mp4
public/assets/ads/scott-brothers-home-depot-lbar.mp4
_Temp/
_Temp_Ads/
# Local-only stash of the original (uncompressed) source images. The deployed
# app uses the optimized JPEGs in public/assets; keep these around in case we
# ever want to re-export at a different size/quality.
_archive/

# Backup artifacts — never shipped in the repo or the Vercel build.
# Keep a local copy for your own reference, but the deployed app must only
# reference the active, imported sources. See
# .cursor/rules/no-backup-artifacts.mdc for the full convention.
*.backup.*
**/_backups/
**/*.backup.json
**/*.backup.mp4
.vercel

# TypeScript incremental build cache (regenerated on every `npm run build`).
*.tsbuildinfo

# Local Claude Code settings (user-specific, not project-wide).
# (Ignore specific local-only files inside .claude/ but DO track .claude/skills/
# so project-level skills like /log-time are shared across the team.)
.claude/settings.json
.claude/settings.local.json
.claude/cache/
