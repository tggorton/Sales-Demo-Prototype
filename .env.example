# Environment overrides for the Sales Demo prototype.
#
# Copy this file to `.env.local` (gitignored) and uncomment / set values to point the
# running build at different media sources. Vite only exposes variables prefixed with
# `VITE_` to the client bundle.
#
# Resolution order at runtime:
#   1. Value from the environment (Vercel Project Settings, shell env, or .env.local)
#   2. Default in `src/demo/constants.ts` — points to the committed, web-optimized
#      files under `public/assets/`.
#
# Typical use cases:
#   - Local dev against the full-quality, un-clipped source files.
#   - A staging deploy that pulls media from S3 / CloudFront instead of the repo.
#   - A/B testing a re-cut or re-encoded variant without changing code.


# -------- Video content --------

# Placeholder video used when no specific content is selected.
# VITE_PLACEHOLDER_VIDEO_URL=/assets/video/Placeholder-SalesDemo-Content_Compresssed.mp4

# Don't Hate Your House main content video. Default is the 61MB pre-spliced two-segment
# build (source 19:45–21:32 + 35:45–44:00 concatenated into a single file, 10:02 long).
# Because the file itself is the splice, `video.currentTime` maps 1:1 onto clip time –
# no source offset is needed. Override this only if you have an equivalent splice at a
# different URL; pointing at the un-spliced full video will desync the scene JSON.
# VITE_DHYH_VIDEO_URL=/assets/video/dhyh-cmp.mp4

# Offset (seconds) into VITE_DHYH_VIDEO_URL where the clip starts. The default shipped
# file IS the clip, so the offset is 0. This hook is kept for forward compatibility
# (e.g. a single-segment re-cut hosted at a different start time).
# VITE_DHYH_VIDEO_SOURCE_OFFSET_SECONDS=0


# -------- Ad creatives --------

# VITE_DHYH_IMPULSE_AD_VIDEO_URL=/assets/ads/SD-HD-Tools-Impulse-1080.mp4
# VITE_DHYH_LBAR_AD_VIDEO_URL=/assets/ads/SD-HD-Tools-L-bar.mp4
# VITE_DHYH_SYNC_AD_VIDEO_URL=/assets/ads/SD-HD-Tools-Sync.mp4
